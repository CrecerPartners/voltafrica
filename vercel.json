{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "apps/landing/dist",
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/events", "destination": "/events.html" },
    { "source": "/voltsquad", "destination": "/voltsquad.html" },
    { "source": "/sales-activations", "destination": "/sales-activations.html" },
    { "source": "/admin/:path*", "destination": "https://digihire-admin.vercel.app/admin/:path*" }
  ],
  "redirects": [
    { "source": "/login", "destination": "https://talents.digihire.io/login", "permanent": false },
    { "source": "/signup", "destination": "https://talents.digihire.io/join-now", "permanent": false },
    { "source": "/join-now", "destination": "https://talents.digihire.io/join-now", "permanent": false },
    { "source": "/dashboard", "destination": "https://talents.digihire.io/dashboard", "permanent": false },
    { "source": "/dashboard/:path*", "destination": "https://talents.digihire.io/dashboard/:path*", "permanent": false },
    { "source": "/onboarding/:path*", "destination": "https://talents.digihire.io/onboarding/:path*", "permanent": false },
    { "source": "/brand", "destination": "https://brands.digihire.io", "permanent": false },
    { "source": "/brand/:path*", "destination": "https://brands.digihire.io/brand/:path*", "permanent": false },
    { "source": "/talent", "destination": "https://talents.digihire.io", "permanent": false },
    { "source": "/talent/:path*", "destination": "https://talents.digihire.io/talent/:path*", "permanent": false },
    { "source": "/academy", "destination": "https://talents.digihire.io/academy", "permanent": false },
    { "source": "/academy/:path*", "destination": "https://talents.digihire.io/academy/:path*", "permanent": false }
  ]
}
